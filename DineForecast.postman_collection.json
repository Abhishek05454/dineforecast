                "api",
                "v1",
                "forecasting",
                "forecast",
                ""
              ],
              "protocol": "http"
            }
          }
        },
        {
          "name": "Get Forecast - Invalid Date (400)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://{{base_url}}/api/v1/forecasting/forecast/?date=not-a-date",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "forecasting",
                "forecast",
                ""
              ],
              "query": [
                {
                  "key": "date",
                  "value": "not-a-date"
                }
              ],
              "protocol": "http"
            }
          }
        }
      ]
    },
