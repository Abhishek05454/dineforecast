{
  "info": {
    "name": "DineForecast",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "localhost:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "username",
      "value": "your_username",
      "type": "string"
    },
    {
      "key": "password",
      "value": "your_password",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Obtain Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access) {",
                  "    pm.collectionVariables.set('access_token', json.access);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "http://{{base_url}}/api/token/",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "token",
                ""
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"<paste_refresh_token_here>\"\n}"
            },
            "url": {
              "raw": "http://{{base_url}}/api/token/refresh/",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "token",
                "refresh",
                ""
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Forecast",
      "item": [
        {
          "name": "Get Forecast",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://{{base_url}}/api/v1/forecasting/forecast/?date=2024-06-10",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "forecasting",
                "forecast",
                ""
              ],
              "query": [
                {
                  "key": "date",
                  "value": "2024-06-10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Forecast - Missing Date (400)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://{{base_url}}/api/v1/forecasting/forecast/",
              "host": [
                "{{base_url}}"
              ],
